# 管理后台配置
# 默认密码: admin123
# 生成密码哈希: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=$2a$10$rXjQZQqZQZQZQZQZQZQZQuR.5YmYmYmYmYmYmYmYmYmYmYmYmYmY
ADMIN_SESSION_SECRET=your-random-secret-key-here

# 微信公众号配置 (可选)
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret

# 小红书配置 (可选)
XIAOHONGSHU_ACCESS_TOKEN=your_xiaohongshu_token
